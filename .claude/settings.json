{
  "permissions": {
    "allow": [
      "Bash(mvn **)",
      "Bash(npm **)",
      "Bash(git **)",
      "Bash(node **)",
      "Bash(python .claude/tools/db-query.py **)",
      "Bash(python .claude/tools/secrets-sync.py **)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Edit(**/.env)",
      "Write(**/.env)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File /d/code/website/.claude/hooks/pre-bash-check.ps1"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "(Read)",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File /d/code/website/.claude/hooks/post-sensitive-read.ps1"
          }
        ]
      },
      {
        "matcher": "(Edit|Write)",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File /d/code/website/.claude/hooks/post-sensitive-scan.ps1"
          },
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File /d/code/website/.claude/hooks/post-edit-check.ps1"
          }
        ]
      }
    ]
  }
}